# Patch: Add ppc64le to Bun's src/env.zig Architecture enum
#
# Adds third variant to Architecture enum + string map + comptime dispatch.
# Npm package name convention: @oven-sh/bun-linux-ppc64le (matches standard
# node convention of ppc64/ppc64le naming).

--- a/src/env.zig
+++ b/src/env.zig
@@ -18,6 +18,7 @@
 pub const isArm = builtin.target.cpu.arch.isArm();
 pub const isAarch64 = builtin.target.cpu.arch.isAarch64();
 pub const isX86 = builtin.target.cpu.arch == .x86;
+pub const isPpc64le = builtin.target.cpu.arch == .powerpc64le;
 pub const isWasm = builtin.target.cpu.arch.isWasm();

@@ -144,6 +145,7 @@
 pub const Architecture = enum {
     x64,
     arm64,
+    ppc64le,
     wasm,

     /// npm package name, `@oven-sh/bun-{os}-{arch}`
@@ -151,6 +153,7 @@
         return switch (this) {
             .x64 => "x64",
             .arm64 => "aarch64",
+            .ppc64le => "ppc64le",
             .wasm => "wasm",
         };
     }
@@ -161,6 +164,8 @@
         .{ "amd64", .x64 },
         .{ "aarch64", .arm64 },
         .{ "arm64", .arm64 },
+        .{ "ppc64le", .ppc64le },
+        .{ "powerpc64le", .ppc64le },
         .{ "wasm", .wasm },
     });
 };
@@ -171,5 +176,7 @@
     .x64
 else if (isAarch64)
     .arm64
+else if (isPpc64le)
+    .ppc64le
 else
     @compileError("Please add your architecture to the Architecture enum");
